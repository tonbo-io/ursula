aws_region    = "us-east-1"
cluster_name  = "ursula-eks"
namespace     = "ursula"
status_bucket = "replace-with-chaos-status-bucket"
image_tag     = "0.3.2"

# These defaults match a Helm release installed with fullnameOverride=ursula.
server_fullname = "ursula"
headless_service = "ursula-headless"
indexer_service = "ursula-indexer"

tags = {
  Environment = "chaos"
  Owner       = "platform"
}

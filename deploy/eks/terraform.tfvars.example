name       = "ursula-production"
aws_region = "us-east-1"
image_tag  = "0.3.1"

# Restrict this to the operator or CI network in production.
cluster_endpoint_public_access_cidrs = ["replace-with-operator-cidr"]

# Optional: the default creates one NAT gateway per AZ. Set true only when the
# lower cost is worth making private-node internet egress depend on one AZ.
single_nat_gateway = false

# Optional globally unique name. Empty generates name-account-region.
s3_bucket_name = ""

# Production capacity baseline. Override these after workload sizing.
server_core_count     = 4
server_cpu_request    = "2"
server_memory_request = "4Gi"
server_memory_limit   = "8Gi"
raft_group_count      = 256
# Keep true only for the first cluster bootstrap, then persist false before
# future generated-values upgrades.
raft_init_membership_per_group = true
raft_volume_size      = "100Gi"
gateway_replicas      = 3
indexer_replicas      = 2

# Enable only after every voter runs a Ursula image that supports compaction.
cold_compaction_enabled = false
cold_compaction_max_streams_per_pass = 16

tags = {
  Environment = "production"
  Owner       = "platform"
}

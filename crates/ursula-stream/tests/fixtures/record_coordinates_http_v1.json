{
  "extension_token":"json-record-coordinates-v1",
  "cases":[
    {
      "name":"json-head-advertises-active-extension",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1},{\"id\":2}]"],
      "operation":"head",
      "expected":{"status":200,"extension":true,"record_first":0,"record_next":3,"next_offset":27}
    },
    {
      "name":"binary-head-does-not-advertise-json-extension",
      "content_type":"application/octet-stream",
      "operation":"head",
      "expected":{"status":200,"extension":false,"next_offset":0}
    },
    {
      "name":"append-acknowledges-contiguous-range",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1},{\"id\":2}]"],
      "operation":"append",
      "body":"[{\"id\":3},{\"id\":4}]",
      "expected":{"status":204,"extension":true,"record_start":3,"record_next":5,"next_offset":45}
    },
    {
      "name":"record-match-failure-reports-current-tails",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1},{\"id\":2}]"],
      "operation":"append",
      "body":"{\"id\":3}",
      "record_match":2,
      "expected":{"status":412,"extension":true,"record_next":3,"next_offset":27}
    },
    {
      "name":"record-aligned-read",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1},{\"id\":2}]"],
      "operation":"read",
      "record":1,
      "max_records":2,
      "expected":{"status":200,"extension":true,"record_first":0,"record_start":1,"record_next":3,"next_offset":27,"body":"{\"id\":1}\n{\"id\":2}\n"}
    },
    {
      "name":"envelope-view-does-not-change-continuation",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1},{\"id\":2}]"],
      "operation":"read",
      "record":1,
      "max_records":2,
      "record_view":"envelope",
      "expected":{"status":200,"extension":true,"record_first":0,"record_start":1,"record_next":3,"next_offset":27,"body":"{\"record\":1,\"value\":{\"id\":1}}\n{\"record\":2,\"value\":{\"id\":2}}\n"}
    },
    {
      "name":"trimmed-record-is-gone",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1},{\"id\":2}]"],
      "retain_from":2,
      "operation":"read",
      "record":1,
      "expected":{"status":410,"extension":true,"record_first":2,"record_next":3}
    },
    {
      "name":"record-beyond-tail-is-bad-request",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1},{\"id\":2}]"],
      "operation":"read",
      "record":4,
      "expected":{"status":400,"extension":true,"record_next":3}
    },
    {
      "name":"record-and-offset-are-mutually-exclusive",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0}]"],
      "operation":"read",
      "record":0,
      "offset_present":true,
      "expected":{"status":400,"extension":true}
    },
    {
      "name":"ordinary-offset-read-remains-byte-oriented",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1}]"],
      "operation":"read",
      "offset_present":true,
      "expected":{"status":200,"extension":true,"next_offset":18,"body":"{\"id\":0}\n{\"id\":1}\n"}
    },
    {
      "name":"empty-long-poll-keeps-record-continuation",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1},{\"id\":2}]"],
      "operation":"read",
      "record":3,
      "live":"long-poll",
      "expected":{"status":204,"extension":true,"record_first":0,"record_start":3,"record_next":3,"next_offset":27,"body":""}
    },
    {
      "name":"sse-control-carries-matching-record-and-offset-tail",
      "content_type":"application/json",
      "setup_bodies":["[{\"id\":0},{\"id\":1},{\"id\":2}]"],
      "operation":"read",
      "record":2,
      "live":"sse",
      "expected":{"status":200,"extension":true,"record_first":0,"record_start":2,"record_next":3,"next_offset":27,"body":"{\"id\":2}\n","sse_control":{"streamFirstRecord":0,"streamNextRecord":3,"streamNextOffset":27,"upToDate":true}}
    }
  ]
}

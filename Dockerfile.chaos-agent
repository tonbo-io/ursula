# syntax=docker/dockerfile:1.7
FROM python:3.12-slim-bookworm

RUN pip install --no-cache-dir awscli==1.45.52 \
  && groupadd --gid 10001 ursula \
  && useradd --uid 10001 --gid 10001 --create-home --shell /usr/sbin/nologin ursula

COPY --chmod=755 scripts/ursula_chaos_agent.py /usr/local/bin/ursula-chaos-agent

USER 10001:10001
WORKDIR /home/ursula
ENTRYPOINT ["python3", "/usr/local/bin/ursula-chaos-agent"]
